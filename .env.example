# Copy to .env and fill in — never commit the copy.

# --- Alpaca credentials ---
# Paper keys by default. Live keys are a separate pair and only used when ALPACA_LIVE=true.
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Trading mode: false = paper (default, safe), true = live real-money trading
ALPACA_LIVE=false

# Market data feed: iex (free tier) or sip (requires paid Alpaca data subscription)
FEED=iex

# --- This service's own API ---
# Key the workflow orchestrator must send in the x-api-key header
SERVICE_API_KEY=

# HTTP server port
PORT=3000

# --- Optional safety rails (unset = no cap) ---
# Reject any order whose notional value exceeds this (USD)
# MAX_ORDER_NOTIONAL=10000
# Reject any order whose share quantity exceeds this
# MAX_ORDER_QTY=100
