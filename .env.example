# Copy to .env for `docker compose`. Secrets — never commit the copy.

# Shared key the orchestrator/agent send to the gateway (x-api-key)
SERVICE_API_KEY=dev-service-key

# research-agent LLM (any OpenAI-compatible endpoint; DeepSeek by default for cost).
# Leave LLM_API_KEY empty to run the agent in skip mode (cron ticks no-op).
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-chat
RESEARCH_SYMBOLS=BTC/USD,ETH/USD
